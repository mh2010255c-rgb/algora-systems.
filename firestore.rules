rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Check if the user is authenticated as an admin in Firebase Auth
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Orders Collection
    match /orders/{orderId} {
      // Anyone can create an order (public landing page submission)
      allow create: if true;
      // Only authenticated admins can read, update, or delete orders
      allow read, update, delete: if isAdmin();
    }
    
    // Notifications Collection
    match /notifications/{notificationId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    // Activities Collection
    match /activities/{activityId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Payments Collection
    match /payments/{paymentId} {
      allow read, write: if isAdmin();
    }

    // Licenses Collection
    match /licenses/{licenseId} {
      allow read, write: if isAdmin();
    }

    // Packages Collection (Public can read, Admin can edit)
    match /packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings Collection (Public can read, Admin can edit)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admins Collection (Admin can read/write their own document)
    match /admins/{adminId} {
      allow read, write: if request.auth != null && request.auth.uid == adminId;
    }
  }
}
